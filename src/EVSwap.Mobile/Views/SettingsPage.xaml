<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             x:Class="EVSwap.Mobile.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Settings" FontSize="28" FontAttributes="Bold" TextColor="#1a1a2e" />

            <Frame BackgroundColor="White" CornerRadius="16" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Biometric Login" FontSize="16" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding IsBiometricEnabled}" Grid.Column="1" OnColor="#0a5c36" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#eee" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Notifications" FontSize="16" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding NotificationsEnabled}" Grid.Column="1" OnColor="#0a5c36" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="16" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="About" FontSize="16" FontAttributes="Bold" TextColor="#1a1a2e" />
                    <Label Text="EV Swap - Battery Swap Management" FontSize="14" TextColor="#666" />
                    <Label Text="{Binding AppVersion, StringFormat='Version {0}'}" FontSize="12" TextColor="#999" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
