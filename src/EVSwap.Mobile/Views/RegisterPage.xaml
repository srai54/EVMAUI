<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             x:Class="EVSwap.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Register"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="16" VerticalOptions="Center">

            <Label Text="Create Account" FontSize="28" FontAttributes="Bold" TextColor="#1a1a2e" />

            <Entry Placeholder="Username" Text="{Binding Username}" BackgroundColor="White" />
            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" BackgroundColor="White" />
            <Entry Placeholder="Phone" Text="{Binding Phone}" Keyboard="Telephone" BackgroundColor="White" />
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" BackgroundColor="White" />
            <Entry Placeholder="Confirm Password" Text="{Binding ConfirmPassword}" IsPassword="True" BackgroundColor="White" />

            <Button Text="Register"
                    Command="{Binding RegisterCommand}"
                    BackgroundColor="#0a5c36"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="12" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#0a5c36" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Already have an account?" TextColor="#666" FontSize="14" />
                <Label Text="Login" TextColor="#0a5c36" FontSize="14" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
