<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             x:Class="EVSwap.Mobile.Views.AdminDashboardPage"
             x:DataType="vm:AdminDashboardViewModel"
             Title="Admin Dashboard"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Admin Dashboard" FontSize="24" FontAttributes="Bold" TextColor="#1a1a2e" />

            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="12" RowSpacing="12">
                <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Users" FontSize="12" TextColor="#666" />
                        <Label Text="{Binding Dashboard.TotalUsers}" FontSize="28" FontAttributes="Bold" TextColor="#0a5c36" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Stations" FontSize="12" TextColor="#666" />
                        <Label Text="{Binding Dashboard.TotalStations}" FontSize="28" FontAttributes="Bold" TextColor="#2980b9" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Batteries" FontSize="12" TextColor="#666" />
                        <Label Text="{Binding Dashboard.BatteriesAvailable}" FontSize="28" FontAttributes="Bold" TextColor="#27ae60" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Today Swaps" FontSize="12" TextColor="#666" />
                        <Label Text="{Binding Dashboard.DailySwaps}" FontSize="28" FontAttributes="Bold" TextColor="#f39c12" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="2" Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Revenue" FontSize="12" TextColor="#666" />
                        <Label Text="{Binding Dashboard.Revenue, StringFormat='${0:F2}'}" FontSize="28" FontAttributes="Bold" TextColor="#8e44ad" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="2" Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Active Riders" FontSize="12" TextColor="#666" />
                        <Label Text="{Binding Dashboard.ActiveRiders}" FontSize="28" FontAttributes="Bold" TextColor="#e67e22" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Label Text="Management" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" Margin="0,10,0,0" />

            <Button Text="User Management"
                    Command="{Binding NavigateToUserManagementCommand}"
                    BackgroundColor="#2980b9" TextColor="White" CornerRadius="8" />
            <Button Text="Fleet Dashboard"
                    Command="{Binding NavigateToFleetCommand}"
                    BackgroundColor="#27ae60" TextColor="White" CornerRadius="8" />
            <Button Text="Maintenance"
                    Command="{Binding NavigateToMaintenanceCommand}"
                    BackgroundColor="#e67e22" TextColor="White" CornerRadius="8" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
