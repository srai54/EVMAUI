<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             xmlns:models="clr-namespace:EVSwap.Mobile.Models"
             x:Class="EVSwap.Mobile.Views.MaintenanceDashboardPage"
             x:DataType="vm:MaintenanceViewModel"
             Title="Maintenance"
             BackgroundColor="#f5f5f5">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadDataCommand}">
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="20">

                <Label Text="Fault Batteries" FontSize="20" FontAttributes="Bold" TextColor="#1a1a2e" />

                <CollectionView ItemsSource="{Binding FaultBatteries}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BatteryModel">
                            <Frame Margin="0,3" Padding="12" BackgroundColor="#fff5f5" CornerRadius="8" HasShadow="True">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="{Binding SerialNumber}" FontSize="14" FontAttributes="Bold" />
                                    <Label Text="{Binding Status}" FontSize="12" TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                           Grid.Column="1" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Maintenance Requests" FontSize="20" FontAttributes="Bold" TextColor="#1a1a2e" Margin="0,10,0,0" />

                <CollectionView ItemsSource="{Binding MaintenanceRequests}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MaintenanceModel">
                            <Frame Margin="0,3" Padding="12" BackgroundColor="White" CornerRadius="8" HasShadow="True">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding IssueType}" FontSize="14" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="#666" MaxLines="2" />
                                    <Label Text="{Binding Status}" FontSize="11"
                                           TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
