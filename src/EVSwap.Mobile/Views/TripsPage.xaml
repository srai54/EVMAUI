<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             xmlns:models="clr-namespace:EVSwap.Mobile.Models"
             x:Class="EVSwap.Mobile.Views.TripsPage"
             x:DataType="vm:TripViewModel"
             Title="Trips"
             BackgroundColor="#f5f5f5">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadTripsCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">

                <Frame BackgroundColor="White" CornerRadius="16" Padding="20" HasShadow="True"
                       IsVisible="{Binding HasActiveTrip}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Active Trip" FontSize="18" FontAttributes="Bold" TextColor="#0a5c36" />
                        <Label Text="{Binding CurrentTrip.StartTime, StringFormat='Started: {0:g}'}" FontSize="14" TextColor="#666" />
                        <Button Text="End Trip"
                                Command="{Binding EndTripCommand}"
                                BackgroundColor="#c0392b"
                                TextColor="White"
                                CornerRadius="8" />
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Start New Trip"
                        Command="{Binding StartTripCommand}"
                        BackgroundColor="#0a5c36"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="12"
                        IsVisible="{Binding HasActiveTrip, Converter={StaticResource InverseBoolConverter}}" />

                <Label Text="Trip History" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" />

                <CollectionView ItemsSource="{Binding Trips}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TripModel">
                            <Frame Margin="0,3" Padding="12" BackgroundColor="White" CornerRadius="8" HasShadow="True">
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                                    <Label Text="{Binding StartTime, StringFormat='{0:MMM dd, yyyy}'}" FontSize="14" FontAttributes="Bold"
                                           Grid.Row="0" Grid.Column="0" />
                                    <Label Text="{Binding DistanceKm, StringFormat='{0:F1} km'}" FontSize="14" TextColor="#0a5c36"
                                           Grid.Row="0" Grid.Column="1" />
                                    <Label Text="{Binding EndTime, StringFormat='Duration: {0:g}'}" FontSize="12" TextColor="#666"
                                           Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
