<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             x:Class="EVSwap.Mobile.Views.QRScanPage"
             x:DataType="vm:QRScanViewModel"
             Title="Scan QR"
             BackgroundColor="#1a1a2e">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Label Text="QR Scanner" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />

        <Frame HeightRequest="250" WidthRequest="250" CornerRadius="16"
               BackgroundColor="#333" HorizontalOptions="Center"
               Padding="20" HasShadow="True">
            <Label Text="📷" FontSize="80" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                   TextColor="#666" />
        </Frame>

        <Label Text="Point camera at station or battery QR code"
               FontSize="14" TextColor="#a0a0a0" HorizontalTextAlignment="Center" />

        <Label Text="-- OR --" FontSize="14" TextColor="#666" HorizontalTextAlignment="Center" />

        <Frame BackgroundColor="White" CornerRadius="12" Padding="16">
            <VerticalStackLayout Spacing="12">
                <Label Text="Enter code manually" FontSize="14" TextColor="#666" />
                <Entry Placeholder="QR Code" Text="{Binding ManualCode}" BackgroundColor="#f5f5f5" />
                <Button Text="Submit"
                        Command="{Binding SubmitManualCodeCommand}"
                        BackgroundColor="#0a5c36"
                        TextColor="White"
                        CornerRadius="8" />
            </VerticalStackLayout>
        </Frame>

        <Button Text="Cancel"
                Command="{Binding CancelCommand}"
                BackgroundColor="Transparent"
                TextColor="#a0a0a0" />

    </VerticalStackLayout>

</ContentPage>
