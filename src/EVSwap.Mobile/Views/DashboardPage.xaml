<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             xmlns:helpers="clr-namespace:EVSwap.Mobile.Helpers"
             x:Class="EVSwap.Mobile.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard"
             BackgroundColor="#f5f5f5">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadDashboardCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">

                <Label Text="{Binding UserName, StringFormat='Hello, {0}'}" FontSize="24" FontAttributes="Bold" TextColor="#1a1a2e" />

                <Frame BackgroundColor="White" CornerRadius="16" Padding="20" HasShadow="True">
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="16">
                        <Label Text="Battery Status" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" Grid.Row="0" Grid.Column="0" />
                        <Label Text="{Binding BatteryPercent, StringFormat='{0:F0}%'}" FontSize="36" FontAttributes="Bold" TextColor="{Binding BatteryPercent, Converter={StaticResource BatteryLevelToColorConverter}}" Grid.Row="1" Grid.Column="0" />
                        <Label Text="{Binding RemainingRange}" FontSize="14" TextColor="#666" Grid.Row="2" Grid.Column="0" />
                        <BoxView Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                 WidthRequest="60" HeightRequest="60" CornerRadius="30"
                                 Color="{Binding BatteryPercent, Converter={StaticResource BatteryLevelToColorConverter}}"
                                 VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <Label Text="{Binding VehicleStatus, StringFormat='Status: {0}'}" TextColor="#666" FontSize="14" />

                <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" Margin="0,10,0,0" />

                <Grid ColumnDefinitions="*, *" ColumnSpacing="12" RowDefinitions="Auto, Auto" RowSpacing="12">
                    <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="📍" FontSize="28" HorizontalTextAlignment="Center" />
                            <Label Text="Find Station" FontSize="14" HorizontalTextAlignment="Center" />
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NavigateToStationsCommand}" />
                            </Frame.GestureRecognizers>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="🔋" FontSize="28" HorizontalTextAlignment="Center" />
                            <Label Text="Swap Battery" FontSize="14" HorizontalTextAlignment="Center" />
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NavigateToSwapCommand}" />
                            </Frame.GestureRecognizers>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="🚗" FontSize="28" HorizontalTextAlignment="Center" />
                            <Label Text="My Trips" FontSize="14" HorizontalTextAlignment="Center" />
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NavigateToTripsCommand}" />
                            </Frame.GestureRecognizers>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True"
                       IsVisible="{Binding IsAdmin}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Admin Stats" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" />
                        <Label Text="{Binding AdminDashboard.TotalUsers, StringFormat='Users: {0}'}" FontSize="14" />
                        <Label Text="{Binding AdminDashboard.ActiveRiders, StringFormat='Active Riders: {0}'}" FontSize="14" />
                        <Label Text="{Binding AdminDashboard.BatteriesAvailable, StringFormat='Batteries: {0}'}" FontSize="14" />
                        <Label Text="{Binding AdminDashboard.TotalStations, StringFormat='Stations: {0}'}" FontSize="14" />
                        <Label Text="{Binding AdminDashboard.DailySwaps, StringFormat='Today Swaps: {0}'}" FontSize="14" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
