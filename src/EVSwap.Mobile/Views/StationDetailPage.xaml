<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             xmlns:models="clr-namespace:EVSwap.Mobile.Models"
             x:Class="EVSwap.Mobile.Views.StationDetailPage"
             x:DataType="vm:StationDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Frame BackgroundColor="White" CornerRadius="16" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding Station.Name}" FontSize="24" FontAttributes="Bold" TextColor="#1a1a2e" />
                    <Label Text="{Binding Station.Address}" FontSize="14" TextColor="#666" />
                    <Label Text="{Binding Station.Status}" FontSize="14"
                           TextColor="{Binding Station.Status, Converter={StaticResource StatusToColorConverter}}" />
                    <Label Text="{Binding Station.DistanceKm, StringFormat='{0:F1} km away'}" FontSize="14" TextColor="#0a5c36" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="16" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Map" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" />
                    <BoxView HeightRequest="150" Color="#e0e0e0" CornerRadius="12">
                        <BoxView.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMapTapped" />
                        </BoxView.GestureRecognizers>
                    </BoxView>
                    <Label Text="Tap to view in maps" FontSize="12" TextColor="#666" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Available Batteries" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e" />

            <CollectionView ItemsSource="{Binding AvailableBatteries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BatteryModel">
                        <Frame Margin="0,3" Padding="12" BackgroundColor="White" CornerRadius="8" HasShadow="True">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                                <Label Text="{Binding SerialNumber}" FontSize="14" FontAttributes="Bold" Grid.Row="0" Grid.Column="0" />
                                <Label Text="{Binding ChargeLevel, StringFormat='{0:F0}%'}" FontSize="14"
                                       TextColor="{Binding ChargeLevel, Converter={StaticResource BatteryLevelToColorConverter}}"
                                       Grid.Row="0" Grid.Column="1" />
                                <Label Text="{Binding Status}" FontSize="12" TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                       Grid.Row="1" Grid.Column="0" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Request Swap"
                    Command="{Binding RequestSwapCommand}"
                    BackgroundColor="#0a5c36"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="12" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
