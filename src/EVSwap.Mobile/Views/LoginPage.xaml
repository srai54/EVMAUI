<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             x:Class="EVSwap.Mobile.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a5c36">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="EV Swap"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

            <Label Text="Battery Swap Management"
                   FontSize="16"
                   TextColor="#a0d8b0"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,30" />

            <Frame BackgroundColor="White" CornerRadius="16" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="16">

                    <Label Text="Welcome Back" FontSize="22" FontAttributes="Bold" TextColor="#1a1a2e" />

                    <Entry Placeholder="Username"
                           Text="{Binding Username}"
                           ReturnType="Next"
                           TextColor="#1a1a2e"
                           BackgroundColor="#f5f5f5" />

                    <Entry Placeholder="Password"
                           Text="{Binding Password}"
                           IsPassword="True"
                           ReturnType="Done"
                           TextColor="#1a1a2e"
                           BackgroundColor="#f5f5f5" />

                    <Button Text="Login"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="#0a5c36"
                            TextColor="White"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="12" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#0a5c36" />

                    <Button Text="Register"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#0a5c36"
                            BorderColor="#0a5c36"
                            BorderWidth="1"
                            HeightRequest="50"
                            CornerRadius="12" />

                    <Button Text="Biometric Login"
                             Command="{Binding BiometricLoginCommand}"
                             BackgroundColor="Transparent"
                             TextColor="#666"
                             FontSize="14" />

                    <Button Text="Bypass Login (Dev)"
                             Command="{Binding BypassLoginCommand}"
                             BackgroundColor="#dc3545"
                             TextColor="White"
                             FontSize="12"
                             HeightRequest="36"
                             CornerRadius="8" />

                    <Label Text="Forgot Password?"
                           TextColor="#0a5c36"
                           HorizontalTextAlignment="Center"
                           FontSize="14">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
