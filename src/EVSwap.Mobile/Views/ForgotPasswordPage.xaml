<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             x:Class="EVSwap.Mobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="Forgot Password"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="16" VerticalOptions="Center">

            <Label Text="Reset Password" FontSize="28" FontAttributes="Bold" TextColor="#1a1a2e" />
            <Label Text="Enter your email to receive an OTP" TextColor="#666" />

            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" BackgroundColor="White" />

            <Button Text="Send OTP"
                    Command="{Binding SendOtpCommand}"
                    BackgroundColor="#0a5c36"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="12"
                    IsVisible="{Binding OtpSent, Converter={StaticResource InverseBoolConverter}}" />

            <Entry Placeholder="Enter OTP" Text="{Binding Otp}" Keyboard="Numeric"
                   IsVisible="{Binding OtpSent}" BackgroundColor="White" />

            <Button Text="Verify OTP"
                    Command="{Binding VerifyOtpCommand}"
                    BackgroundColor="#0a5c36"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="12"
                    IsVisible="{Binding OtpSent}"
                    IsEnabled="{Binding OtpVerified, Converter={StaticResource InverseBoolConverter}}" />

            <Entry Placeholder="New Password" Text="{Binding NewPassword}" IsPassword="True"
                   IsVisible="{Binding OtpVerified}" BackgroundColor="White" />

            <Button Text="Reset Password"
                    Command="{Binding ResetPasswordCommand}"
                    BackgroundColor="#0a5c36"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="12"
                    IsVisible="{Binding OtpVerified}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#0a5c36" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
