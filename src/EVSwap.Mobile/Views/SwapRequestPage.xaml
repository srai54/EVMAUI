<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EVSwap.Mobile.ViewModels"
             xmlns:models="clr-namespace:EVSwap.Mobile.Models"
             x:Class="EVSwap.Mobile.Views.SwapRequestPage"
             x:DataType="vm:SwapRequestViewModel"
             Title="Request Swap"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="New Swap Request" FontSize="24" FontAttributes="Bold" TextColor="#1a1a2e" />

            <Label Text="Select Station" FontSize="14" TextColor="#666" />
            <Picker ItemsSource="{Binding Stations}"
                    SelectedItem="{Binding SelectedStation}"
                    ItemDisplayBinding="{Binding Name}"
                    Title="Choose Station"
                    BackgroundColor="White" />

            <Label Text="Vehicle ID" FontSize="14" TextColor="#666" />
            <Entry Text="{Binding VehicleId}" Keyboard="Numeric" BackgroundColor="White" />

            <Label Text="Battery Type" FontSize="14" TextColor="#666" />
            <Picker ItemsSource="{Binding BatteryTypes}"
                    SelectedItem="{Binding BatteryType}"
                    Title="Select Type"
                    BackgroundColor="White" />

            <Button Text="Submit Request"
                    Command="{Binding SubmitRequestCommand}"
                    BackgroundColor="#0a5c36"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="12" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#0a5c36" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
